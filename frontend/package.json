{
  "name": "buildtask",
  "productName": "BuildTask",
  "private": true,
  "version": "1.0.0",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:start": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.buildtask.app",
    "productName": "BuildTask",
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": "portable",
      "icon": "src/assets/buildtask_logo.ico"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist"
      }
    ]
  }
}